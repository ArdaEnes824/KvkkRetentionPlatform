@model IEnumerable<KvkkRetentionPlatform.Models.Entities.JobApplication>
@{
    ViewData["Title"] = "Başvurularım";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold"><i class="bi bi-file-earmark-check text-primary me-2"></i>Başvurularım</h2>
        <p class="text-muted">Açık pozisyonlara yaptığınız başvuruları ve mevcut durumlarını aşağıdan takip edebilirsiniz.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted p-5">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-3">Henüz hiçbir ilana başvuru yapmadınız.</p>
                <a href="/CandidatePanel/OpenJobs" class="btn btn-primary mt-2">Açık İlanları İncele</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">İlan Başlığı</th>
                            <th>Departman</th>
                            <th>Başvuru Tarihi</th>
                            <th>Durum</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold align-middle">@app.JobPosting.Title</td>
                                <td class="align-middle">@app.JobPosting.Department</td>
                                <td class="align-middle">@app.ApplicationDate.ToString("dd MMM yyyy, HH:mm")</td>
                                <td class="align-middle">
                                    @if(app.Status == "Bekleniyor")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Bekleniyor</span>
                                    }
                                    else if(app.Status == "Onaylandı")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Onaylandı</span>
                                    }
                                    else if(app.Status == "Reddedildi")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Reddedildi</span>
                                    }
                                    else if(app.Status == "İptal Edildi")
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-x-square me-1"></i>İptal Edildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@app.Status</span>
                                    }
                                </td>
                                <td>
                                    @if(app.Status == "Bekleniyor")
                                    {
                                        <form asp-action="CancelApplication" method="post" class="d-inline" onsubmit="return confirm('Bu başvuruyu iptal etmek istediğinize emin misiniz?');">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Başvuruyu İptal Et">
                                                <i class="bi bi-trash"></i> İptal
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
