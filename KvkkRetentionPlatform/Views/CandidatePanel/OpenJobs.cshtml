@model IEnumerable<KvkkRetentionPlatform.Models.Entities.JobPosting>
@{
    ViewData["Title"] = "Açık İlanlar";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold"><i class="bi bi-briefcase text-primary me-2"></i>Açık İlanlar</h2>
        <p class="text-muted">Kariyerinize yön verecek güncel açık pozisyonlarımıza buradan başvuru yapabilirsiniz.</p>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted p-5">
            <i class="bi bi-folder-x display-1"></i>
            <p class="mt-3">Şu an için açık ilanımız bulunmamaktadır. Lütfen daha sonra tekrar kontrol edin.</p>
        </div>
    }
    
    @foreach (var job in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm custom-hover-card border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-primary mb-2">@job.Title</h5>
                    <p class="text-muted small mb-3">
                        <i class="bi bi-building me-1"></i> @job.Department &bull; 
                        <i class="bi bi-clock me-1"></i> @job.CreatedAt.ToString("dd MMM yyyy")
                    </p>
                    <p class="card-text text-secondary mb-4">
                        @(job.Description.Length > 100 ? job.Description.Substring(0, 100) + "..." : job.Description)
                    </p>
                    <form asp-action="ApplyToJob" method="post" class="mt-auto">
                        <input type="hidden" name="jobId" value="@job.Id" />
                        <button type="submit" class="btn btn-outline-primary w-100">Hemen Başvur</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .custom-hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 10px;
    }
    .custom-hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>
