@model KvkkRetentionPlatform.Models.RegisterViewModel
@{
    ViewData["Title"] = "İş Başvurusu & Kayıt";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow border-0">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold">Aday Kayıt Formu</h2>
                    <p class="text-muted">Geleceğinize yön vermek için ilk adımı atın.</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label">Adınız</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label">Soyadınız</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">E-Posta Adresi</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Tckn" class="form-label">TC Kimlik No</label>
                            <input asp-for="Tckn" class="form-control" maxlength="11" />
                            <span asp-validation-for="Tckn" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">Telefon Numarası</label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Şifre</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4 mt-3 bg-light p-3 rounded border">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="IsKvkkAccepted" id="chkKvkk" disabled />
                            <label class="form-check-label fw-bold" for="chkKvkk">
                                <a href="#" data-bs-toggle="modal" data-bs-target="#kvkkModal" class="text-decoration-underline text-primary">KVKK Aydınlatma Metni</a>'ni okudum, iletişim verilerimin işlenmesine AÇIK RIZA veriyorum.
                            </label>
                        </div>
                        <span asp-validation-for="IsKvkkAccepted" class="text-danger d-block mt-1"></span>
                        <small class="text-muted d-block mt-2"><i class="fa-solid fa-circle-info"></i> Onay verebilmek için lütfen önce Aydınlatma Metni'ni okuyunuz.</small>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success btn-lg">Başvurumu Tamamla</button>
                    </div>
                </form>
                
                <div class="text-center mt-4 pt-3 border-top">
                    <p class="text-muted mb-0">Daha önce başvuru yaptınız mı? <a href="/Auth/Login" class="text-decoration-none fw-bold">Aday Girişi</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KVKK Modal -->
<div class="modal fade" id="kvkkModal" tabindex="-1" aria-labelledby="kvkkModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="kvkkModalLabel"><i class="fa-solid fa-shield-halved"></i> KVKK Aydınlatma Metni</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <div class="modal-body text-start">
        <h6>1. Veri Sorumlusunun Kimliği</h6>
        <p class="small text-muted">Şirketimiz (Veri Sorumlusu), aday başvuru süreçlerinde veri güvenliğinize büyük önem vermektedir.</p>
        
        <h6>2. Kişisel Verilerin İşlenme Amacı</h6>
        <p class="small text-muted">Toplanan kimlik (Ad, Soyad, TC Kimlik), iletişim (E-posta, Telefon) ve mesleki deneyim (Özgeçmiş) verileriniz yalnızca işe alım süreçlerinin yürütülmesi ve değerlendirilmesi amacıyla işlenmektedir.</p>

        <h6>3. İşlenen Kişisel Verilerin Kimlere ve Hangi Amaçla Aktarılabileceği</h6>
        <p class="small text-muted">Kişisel verileriniz, kanuni istisnalar hariç olmak üzere, açık rızanız olmaksızın üçüncü şahıslarla paylaşılmamaktadır.</p>

        <h6>4. Kişisel Veri Toplamanın Yöntemi ve Hukuki Sebebi</h6>
        <p class="small text-muted">Verileriniz, elektronik ortamda doldurduğunuz bu form aracılığıyla "ilgili kişinin temel hak ve özgürlüklerine zarar vermemek kaydıyla, veri sorumlusunun meşru menfaatleri için veri işlenmesinin zorunlu olması" hukuki sebebine dayanarak otomatik yollarla işlenmektedir. Onayınız ile birlikte IP adresiniz ve onay tarihiniz kanuni ispat yükümlülüğü gereği kayıt altına alınacaktır.</p>

        <h6>5. KVKK Madde 11 Kapsamındaki Haklarınız</h6>
        <p class="small text-muted">Kanun'un 11. maddesi uyarınca; verilerinizin işlenip işlenmediğini öğrenme, silinmesini (Unutulma Hakkı) veya yok edilmesini ve anonimleştirilmesini isteme haklarına sahipsiniz.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
        <button type="button" class="btn btn-success" id="btnAcceptKvkk" data-bs-dismiss="modal"><i class="fa-solid fa-check-circle"></i> Okudum ve Onaylıyorum</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var btnAccept = document.getElementById("btnAcceptKvkk");
            var chkKvkk = document.getElementById("chkKvkk");
            var form = chkKvkk.closest("form");
            
            if(btnAccept && chkKvkk) {
                btnAccept.addEventListener("click", function() {
                    chkKvkk.removeAttribute("disabled");
                    chkKvkk.checked = true;
                });

                // Kullanıcı metni okumadan checkbox'ı değiştiremesin
                chkKvkk.addEventListener("click", function(e) {
                    if (chkKvkk.hasAttribute("disabled") || !chkKvkk.checked) {
                        e.preventDefault();
                        var modal = new bootstrap.Modal(document.getElementById('kvkkModal'));
                        modal.show();
                    }
                });

                // Allow MVC to post the hidden field even if disabled dynamically (if we re-disabled it)
                form.addEventListener("submit", function() {
                    if(!chkKvkk.hasAttribute("disabled")) {
                        chkKvkk.removeAttribute("disabled");
                    }
                });
            }
        });
    </script>
}
