@model IEnumerable<KvkkRetentionPlatform.Models.Entities.AuditLog>

@{
    ViewData["Title"] = "Denetim İzleri (Kara Kutu)";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Denetim İzleri (Kara Kutu)</h1>
</div>

<div class="card shadow mb-4 bg-dark text-white">
    <div class="card-header py-3 bg-black border-bottom border-secondary">
        <h6 class="m-0 fw-bold text-light"><i class="fa-solid fa-server"></i> Sistem Logları</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-dark table-hover text-white w-100 align-middle">
                <thead class="text-white">
                    <tr>
                        <th class="text-white">ID</th>
                        <th class="text-white">Tablo</th>
                        <th class="text-white">Kayıt ID</th>
                        <th class="text-white">Aksiyon</th>
                        <th class="text-white">Tarih</th>
                        <th class="text-white">Kullanıcı</th>
                        <th class="text-white">Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr class="text-white">
                            <td class="text-white">#@log.Id</td>
                            <td class="text-white"><span class="badge bg-secondary text-white">@log.TableName</span></td>
                            <td class="text-white">@log.RecordId</td>
                            <td class="text-white">
                                @if (log.Action.ToUpper().Contains("DELETE") || log.Action.ToUpper().Contains("SİL") || log.Action.ToUpper().Contains("YOK ET") || log.Action.ToUpper().Contains("GERİ ÇEKİLDİ"))
                                {
                                    <span class="badge bg-danger text-white">@log.Action</span>
                                }
                                else if(log.Action.ToUpper().Contains("UPDATE") || log.Action.ToUpper().Contains("GÜNCELLE") || log.Action.ToUpper().Contains("INSERT"))
                                {
                                    <span class="badge bg-warning text-dark">@log.Action</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@log.Action</span>
                                }
                            </td>
                            <td class="text-white">@log.ActionDate.ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td class="text-white">@log.PerformedBy</td>
                            <td class="text-white fs-6">@log.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
