<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KVKK Yönetim Paneli</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KvkkRetentionPlatform.styles.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fc;
        }
        .sidebar {
            height: 100vh;
            background-color: #4e73df;
            background-image: linear-gradient(180deg,#4e73df 10%,#224abe 100%);
            background-size: cover;
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            z-index: 100;
        }
        .sidebar-brand {
            color: #fff;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 700;
            padding: 1.5rem 1rem;
            display: block;
            text-align: center;
        }
        .nav-link {
            color: rgba(255,255,255,.8);
            padding: 1rem;
            font-weight: 600;
            margin: 0 10px;
        }
        .nav-link:hover, .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,.1);
            border-radius: 5px;
        }
        .nav-link i {
            margin-right: 10px;
        }
        .content-wrapper {
            margin-left: 250px;
            padding: 20px;
            min-height: 100vh;
        }
    </style>
</head>
<body>
    @{
        var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
        var isPublicPage = controllerName == "Home" || controllerName == "Auth";
    }

    <!-- Sidebar -->
    @if(!isPublicPage && User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <nav class="sidebar d-flex flex-column">
        <a class="sidebar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
            <i class="fa-solid fa-shield-halved"></i> KVKK Yönetim
        </a>
        <hr class="sidebar-divider my-0 text-white-50">
        <ul class="nav flex-column mt-3">
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-fw fa-tachometer-alt"></i>
                    <span>Ana Sayfa (Dashboard)</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="DataSubjects" asp-action="Index">
                    <i class="fa-solid fa-fw fa-users"></i>
                    <span>Kayıtlı Kullanıcılar</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="DataSubjects" asp-action="Create">
                    <i class="fa-solid fa-fw fa-user-plus"></i>
                    <span>Yeni İlgili Kişi Ekle</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="Consents" asp-action="Index">
                    <i class="fa-solid fa-fw fa-handshake"></i>
                    <span>Açık Rıza Yönetimi</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="AuditLogs" asp-action="Index">
                    <i class="fa-solid fa-fw fa-list-check"></i>
                    <span>Denetim İzleri (Kara Kutu)</span>
                </a>
            </li>
            <li class="nav-item mt-4">
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" id="logoutFormAdmin" class="d-none"></form>
                <a class="nav-link text-warning" href="#" onclick="document.getElementById('logoutFormAdmin').submit(); return false;">
                    <i class="fa-solid fa-fw fa-sign-out-alt"></i>
                    <span>Çıkış Yap</span>
                </a>
            </li>
        </ul>
        </nav>
    }

    @if(!isPublicPage && User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Candidate"))
    {
        <nav class="sidebar d-flex flex-column" style="background-color: #2e59d9; background-image: linear-gradient(180deg,#2e59d9 10%,#1a3c9b 100%);">
            <a class="sidebar-brand" asp-area="" asp-controller="CandidatePanel" asp-action="Index">
                <i class="fa-solid fa-user-graduate"></i> Aday Portalı
            </a>
            <hr class="sidebar-divider my-0 text-white-50">
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="CandidatePanel" asp-action="Index">
                        <i class="fa-solid fa-fw fa-user"></i>
                        <span>Profilim</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="CandidatePanel" asp-action="OpenJobs">
                        <i class="fa-solid fa-fw fa-briefcase"></i>
                        <span>Açık İlanlar</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="CandidatePanel" asp-action="MyApplications">
                        <i class="fa-solid fa-fw fa-file-signature"></i>
                        <span>Başvurularım</span>
                    </a>
                </li>
                <li class="nav-item mt-4">
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" id="logoutFormCandidate" class="d-none"></form>
                    <a class="nav-link text-warning" href="#" onclick="document.getElementById('logoutFormCandidate').submit(); return false;">
                        <i class="fa-solid fa-fw fa-sign-out-alt"></i>
                        <span>Çıkış Yap</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
    
    <!-- Content Wrapper -->
    <div class="content-wrapper" style="@(isPublicPage ? "margin-left: 0;" : "")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
        
        <footer class="border-top footer text-muted mt-5 py-3 text-center">
            <div class="container">
                &copy; 2026 - KVKK Retention Platform
            </div>
        </footer>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
