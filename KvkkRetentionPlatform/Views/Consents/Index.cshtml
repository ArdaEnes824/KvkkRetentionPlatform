@model IEnumerable<KvkkRetentionPlatform.Models.Entities.VwActiveConsentLog>

@{
    ViewData["Title"] = "Açık Rıza Yönetimi";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Açık Rıza Yönetimi</h1>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 fw-bold text-primary">Aktif Rızalar Listesi</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover w-100 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Müşteri Adı</th>
                        <th>Kategori</th>
                        <th>Onay Tarihi</th>
                        <th>Geçen Ay</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.SubjectFullName</td>
                                <td><span class="badge bg-info text-dark">@item.CategoryName</span></td>
                                <td>@item.ConsentDate.ToString("dd.MM.yyyy")</td>
                                <td>@item.MonthsSinceConsent Ay</td>
                                <td>
                                    <form asp-action="RevokeConsent" asp-route-id="@item.ConsentId" method="post" class="m-0" onsubmit="return confirm('Bu rızayı geri çekmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-ban"></i> Rızayı Geri Çek
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center">Aktif rıza kaydı bulunmamaktadır.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
