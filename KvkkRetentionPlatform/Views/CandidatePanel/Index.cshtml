@model KvkkRetentionPlatform.Models.CandidatePanelViewModel
@{
    ViewData["Title"] = "Başvurum ve Gizlilik Ayarlarım";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold"><i class="bi bi-person-badge text-primary me-2"></i>Aday Paneli</h2>
        <p class="text-muted">Başvuru durumunuzu ve kişisel veri tercihlerinizi bu ekrandan yönetebilirsiniz.</p>
    </div>
    <div class="col-md-4 text-md-end text-start">
        <span class="badge bg-success p-2 fs-6"><i class="bi bi-shield-check me-1"></i>KVKK Korumasında</span>
    </div>
</div>

<div class="row">
    <!-- Profil ve Veriler -->
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom p-4">
                <h5 class="mb-0 fw-bold">Kişisel Bilgileriniz</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted"><strong>Ad Soyad</strong></div>
                    <div class="col-sm-8 fw-semibold">@Model.Subject.FirstName @Model.Subject.LastName</div>
                </div>
                <hr class="text-muted opacity-25">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted"><strong>E-Posta</strong></div>
                    <div class="col-sm-8">@Model.Subject.Email</div>
                </div>
                <hr class="text-muted opacity-25">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted"><strong>TCKN (Maskeli)</strong></div>
                    <div class="col-sm-8">
                        <span class="font-monospace bg-light px-2 py-1 rounded border">@Model.MaskedTckn</span>
                    </div>
                </div>
                <hr class="text-muted opacity-25">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted"><strong>Telefon (Maskeli)</strong></div>
                    <div class="col-sm-8">
                        <span class="font-monospace bg-light px-2 py-1 rounded border">@Model.MaskedPhone</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Rıza Durumu -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom p-4">
                <h5 class="mb-0 fw-bold">Açık Rıza Durumu</h5>
            </div>
            <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                @if (Model.IsConsentActive)
                {
                    <div class="mb-3">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-success fw-bold">Aktif</h5>
                    <p class="text-muted small">İletişim verilerinizin yeni ilanlar için işlenmesine verdiğiniz açık rıza <strong>geçerlidir</strong>.</p>
                }
                else
                {
                    <div class="mb-3">
                        <i class="bi bi-x-circle-fill text-secondary" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-secondary fw-bold">Pasif</h5>
                    <p class="text-muted small">Herhangi bir aktif açık rızanız bulunmamaktadır.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Profil Guncelleme Formu -->
<div class="card shadow-sm border-0 mt-4 bg-white mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-person-lines-fill text-primary me-2"></i>Özgeçmiş ve Profil Güncelleme</h5>
        <p class="text-muted">Eğitim, iş geçmişiniz ve özgeçmiş dosyanızı güncelleyerek başvurularınızda avantaj sağlayın.</p>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="firstName" class="form-label fw-bold">Adınız</label>
                    <input type="text" name="firstName" id="firstName" class="form-control" value="@Model.Subject.FirstName" />
                </div>
                <div class="col-md-6">
                    <label for="lastName" class="form-label fw-bold">Soyadınız</label>
                    <input type="text" name="lastName" id="lastName" class="form-control" value="@Model.Subject.LastName" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="emailAddr" class="form-label fw-bold">E-Posta Adresiniz</label>
                    <input type="email" name="emailAddr" id="emailAddr" class="form-control" placeholder="Mevcut veya yeni e-posta adresi..." />
                </div>
                <div class="col-md-6">
                    <label for="phoneNumber" class="form-label fw-bold">Telefon Numaranız</label>
                    <input type="text" name="phoneNumber" id="phoneNumber" class="form-control" placeholder="Güncel telefon numaranız..." />
                </div>
            </div>

            <div class="mb-3">
                <label for="education" class="form-label fw-bold">Eğitim Geçmişi</label>
                <textarea name="education" id="education" class="form-control" rows="3" placeholder="Örn: X Üniversitesi, Y Bölümü (2018-2022)"></textarea>
            </div>
            
            <div class="mb-3">
                <label for="workExperience" class="form-label fw-bold">Çalışma Geçmişi</label>
                <textarea name="workExperience" id="workExperience" class="form-control" rows="3" placeholder="Örn: Z Şirketi - Yazılım Geliştirici (2022-2024)"></textarea>
            </div>
            
            <div class="mb-4">
                <label for="cvFile" class="form-label fw-bold">CV Yükele (Sadece PDF)</label>
                <input type="file" name="cvFile" id="cvFile" class="form-control file-input border-secondary" accept=".pdf" />
                <div class="form-text">PDF formatında belgenizi seçin.</div>
            </div>
            
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-cloud-arrow-up-fill me-2"></i>Profili Güncelle ve Kaydet</button>
            </div>
        </form>
    </div>
</div>

<!-- Self Servis KVKK Butonları -->
<div class="card shadow-sm border-0 mt-2 bg-light">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-sliders text-primary me-2"></i>KVKK Veri Yönetimi</h5>
        <p class="text-muted mb-4">Kişisel verileriniz üzerindeki haklarınızı aşağıdaki butonları kullanarak self-servis olarak kullanabilirsiniz.</p>
        
        <div class="d-flex flex-wrap gap-3">
            <a href="/DataSubjects/ExportUserData?email=@Model.Subject.Email" class="btn btn-outline-primary btn-lg mb-2 w-100 text-start">
                <i class="bi bi-download me-2"></i> Verilerimi İndir (JSON Export)
            </a>
            
            <div class="alert alert-danger mt-3 mb-2 p-3 border-danger d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill text-danger fs-3 me-3"></i>
                <div>
                    <strong>Tehlikeli Bölge:</strong> Unutulma hakkınızı kullanarak Profilinizin, KVKK izinlerinizin ve yüklediğiniz PDF Özgeçmiş belgenizin sunucudan "kalıcı olarak" silinmesini sağlayabilirsiniz.
                </div>
            </div>
            
            <form asp-action="DeleteMyAccount" method="post" class="w-100 m-0 p-0" onsubmit="return confirm('Bu işlem GERİ ALINAMAZ! Tüm kişisel verileriniz ve PDF dosyalarınız kalıcı olarak (fiziksel diskten) imha edilecektir. Emin misiniz?');">
                <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">
                    <i class="fa-solid fa-skull-crossbones me-2"></i> Hesabımı ve Tüm Verilerimi Sil
                </button>
            </form>
        </div>
    </div>
</div>
